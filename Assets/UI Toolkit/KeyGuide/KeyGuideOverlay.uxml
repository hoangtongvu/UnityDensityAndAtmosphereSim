                <ui:VisualElement class="key-cap-wrap" style="flex-direction: row;">
                    <ui:VisualElement class="key-icon" style="background-image: url(&quot;project://database/Assets/GameInputControllerIconsFree/keyboard/keyboard-solid/w.png?fileID=2800000&amp;guid=c48a9e623f57a964bb290afc4c88ec5e&amp;type=3#w&quot;);"/>
                    <ui:VisualElement class="key-icon" style="background-image: url(&quot;project://database/Assets/GameInputControllerIconsFree/keyboard/keyboard-solid/a.png?fileID=2800000&amp;guid=84336ead2bc884a4389f3d4e11093845&amp;type=3#a&quot;);"/>
                    <ui:VisualElement class="key-icon" style="background-image: url(&quot;project://database/Assets/GameInputControllerIconsFree/keyboard/keyboard-solid/s.png?fileID=2800000&amp;guid=39c87eb429428fe49a2621871ade9193&amp;type=3#s&quot;);"/>
                    <ui:VisualElement class="key-icon" style="background-image: url(&quot;project://database/Assets/GameInputControllerIconsFree/keyboard/keyboard-solid/d.png?fileID=2800000&amp;guid=f88a3bde663a377419f80eeae083d5b7&amp;type=3#d&quot;);"/>
